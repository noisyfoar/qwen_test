<Window x:Class="ShellExtension.Formats.LIS.Dialogs.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка LIS"
        Height="600"
        Width="1000">

    <Window.Resources>
        <Thickness x:Key="margin" Left="8" Top="2" Right="8" Bottom="2"/>
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="3,5,3,5"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="MinWidth" Value="36"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="{StaticResource margin}">
            <TextBlock Text="Шаблон настроек" VerticalAlignment="Center"/>
            <ComboBox Width="180" Margin="6,0,0,0">
                <ComboBoxItem Content="Шаблон 1"/>
                <ComboBoxItem Content="Шаблон 2"/>
                <ComboBoxItem Content="Шаблон 3"/>
            </ComboBox>
            <Button Content="Сохранить" Margin="8,0,0,0" Padding="12,2"/>
            <Button Content="Сохранить как" Margin="8,0,0,0" Padding="12,2"/>
        </StackPanel>

        <Separator DockPanel.Dock="Top"/>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,3">
            <TextBlock Text="Старт:" VerticalAlignment="Center"/>
            <TextBox Width="90" Margin="6,0,0,0" Text="0"/>
            <TextBlock Text="Стоп:" Margin="12,0,0,0" VerticalAlignment="Center"/>
            <TextBox Width="90" Margin="6,0,0,0" Text="100"/>
            <Button Content="Весь диапазон" Margin="12,0,0,0" Padding="12,2"/>
        </StackPanel>

        <Separator DockPanel.Dock="Top"/>

        <Grid DockPanel.Dock="Bottom" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="Отмена"
                    Margin="0,0,8,0"
                    Padding="15,4"
                    Command="{Binding CancelCommand}"/>
            <Button Grid.Column="1"
                    Content="Готово"
                    Padding="15,4"
                    IsDefault="True"
                    Command="{Binding DoneCommand}"/>
        </Grid>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Таблицы параметров" Grid.Column="0" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Таблица:" VerticalAlignment="Center"/>
                        <ComboBox Width="220"
                                  Margin="6,0,0,0"
                                  ItemsSource="{Binding ParameterTables}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedParameterTable}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SelectedParameterTable.Rows}"
                              AutoGenerateColumns="True"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True"
                              HeadersVisibility="Column"/>
                </Grid>
            </GroupBox>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="Доступные кривые" Grid.Column="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0"
                                 Margin="0,0,0,6"
                                 Text="{Binding CurveFilter, UpdateSourceTrigger=PropertyChanged}"/>
                        <ListBox Grid.Row="1"
                                 SelectionMode="Extended"
                                 ItemsSource="{Binding AvailableCurvesView}"
                                 SelectedItem="{Binding SelectedAvailableCurve, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding SourceName}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Units}"
                                                   Foreground="Gray"
                                                   Margin="10,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                    <Button Style="{StaticResource ArrowButtonStyle}" Content=">" Command="{Binding MoveSelectedRightCommand}"/>
                    <Button Style="{StaticResource ArrowButtonStyle}" Content="<" Command="{Binding MoveSelectedLeftCommand}"/>
                    <Button Style="{StaticResource ArrowButtonStyle}" Content=">>" Command="{Binding MoveAllRightCommand}"/>
                    <Button Style="{StaticResource ArrowButtonStyle}" Content="<<" Command="{Binding MoveAllLeftCommand}"/>
                </StackPanel>

                <GroupBox Header="Выбранные кривые" Grid.Column="2">
                    <DataGrid ItemsSource="{Binding SelectedCurves}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              SelectionMode="Extended"
                              SelectedItem="{Binding SelectedSelectedCurve, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Исх. имя" Binding="{Binding SourceName}" IsReadOnly="True" Width="2*"/>
                            <DataGridTextColumn Header="Эксп. имя" Binding="{Binding ExportName}" Width="2*"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="3*"/>
                            <DataGridTextColumn Header="Точн." Binding="{Binding Precision}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
