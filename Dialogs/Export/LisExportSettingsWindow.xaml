<Window x:Class="ShellExtension.Formats.LIS.Dialogs.LisExportSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit" 
        xmlns:shell="clr-namespace:NPFGEO.Shell;assembly=Genesis" 
        xmlns:controls="clr-namespace:NPFGEO.Controls;assembly=GeoControls"
        mc:Ignorable="d" 
        Background="WhiteSmoke" x:Name="root"
        Width="260" Height="140" WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" ResizeMode="NoResize"
      Title="Настройки экспорта LIS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Шаг" VerticalAlignment="Center"
                   Margin="10,0,0,0" 
                   Grid.Column="0" Grid.Row="0"/>

        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0">
            <controls:GenesisTextBox Minimum="0.001" 
                                Width="100" Height="25" Margin="5, 0, 0, 0" TextAlignment="Left" Text="{Binding Path=Step, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{F:0}}"/>
            <TextBlock Margin="5,0,0,0" Text="M" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="Целый шаг LIS" VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   Grid.Column="0" Grid.Row="1"/>

        <StackPanel Orientation="Horizontal"
                    Grid.Column="1" Grid.Row="1">
            <TextBlock Text="{Binding Path=LISStep, Mode=TwoWay}" VerticalAlignment="Center"
                       Margin="5,0,0,0"/>

            <TextBlock Text="{Binding Path=LISstepUnit, Mode=TwoWay}" VerticalAlignment="Center"
                       Margin="5,0,0,0"/>
        </StackPanel>

        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center"
                Name="NumberSaveButton" Margin="5" Width="80" Height="25" Click="Button_Click" Content="OK" FontSize="15"></Button>
    </Grid>
</Window>
