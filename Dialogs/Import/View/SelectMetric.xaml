<UserControl x:Class="NPFGEO.IO.LAS.Import.View.SelectMetric"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NPFGEO.IO.LAS.Import.View"
             xmlns:tookit="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:vm="clr-namespace:NPFGEO.IO.LAS.Import.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <GridLength x:Key="splitterWidth">3</GridLength>
        <GridLength x:Key="valueWidth">150</GridLength>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <Expander Header="Исходные данные" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Margin="0" DataContext="{Binding Path=Model, Mode=OneTime}" BorderThickness="1" BorderBrush="LightGray" DockPanel.Dock="Bottom">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="{StaticResource splitterWidth}"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="sourceDataGrid" DataContextChanged="sourceDataGrid_DataContextChanged" ItemsSource="{Binding Path=Data, Mode=OneTime}" Grid.Row="2"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserSortColumns="False" AutoGenerateColumns="False" IsReadOnly="True"
                      EnableRowVirtualization="True">

                </DataGrid>
                <GridSplitter Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Foreground="Transparent" Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
            </Grid>
        </Expander>


        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40*"/>
                <ColumnDefinition Width="{StaticResource splitterWidth}"/>
                <ColumnDefinition Width="60*"/>
            </Grid.ColumnDefinitions>
            <GridSplitter Grid.Column="1" Grid.Row="0" Foreground="Transparent" Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>


            <GroupBox Header="Параметры" Grid.Column="0" Grid.Row="0">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Vertical" Grid.IsSharedSizeScope="True">
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Метрика" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                            <ComboBox SelectedItem="{Binding Path=CurrentMetric, Mode=TwoWay}" ItemsSource="{Binding Path=Metrics, Mode=OneTime}" Grid.Column="1" Margin="0">
                                <ComboBox.Resources>
                                    <DataTemplate DataType="{x:Type vm:Time}">
                                        <TextBlock Text="Время"/>
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type vm:Depth}">
                                        <TextBlock Text="Глубина"/>
                                    </DataTemplate>
                                </ComboBox.Resources>
                            </ComboBox>
                        </Grid>
                        <ContentPresenter Content="{Binding Path=CurrentMetric, Mode=OneWay}">
                            <ContentPresenter.Resources>
                                <DataTemplate DataType="{x:Type vm:Depth}">
                                    <StackPanel Orientation="Vertical">
                                        <Grid Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Кривая глубины" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=OneWay}"
                                                  Visibility="Collapsed" 
                                                  ToolTip="Если глубины были заданы в убывающем порядке - ☑"
                                                  Focusable="False" IsHitTestVisible="False"  Content="Реверсивный порядок"/>
                                    </StackPanel>
                                </DataTemplate>

                                <DataTemplate DataType="{x:Type vm:Time}">
                                    <StackPanel Orientation="Vertical">
                                        <Grid Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Формат" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                            <ComboBox SelectedItem="{Binding Path=CurrentFormat, Mode=TwoWay}" ItemsSource="{Binding Path=Formats, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                <ComboBox.Resources>
                                                    <DataTemplate DataType="{x:Type vm:FromPlusTimeCurveFormat}">
                                                        <TextBlock Text="Пар-р начало + время"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type vm:DateDotTimeFormat}">
                                                        <TextBlock Text="Дата.Время"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type vm:ReverseDateDotTimeFormat}">
                                                        <TextBlock Text="Рев. Дата.Время"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type vm:ReverseDateTimeDotMSFormat}">
                                                        <TextBlock Text="Рев. ДатаВремя.мс"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type vm:OleTimeFormat}">
                                                        <TextBlock Text="OLE формат"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type vm:UtcTimeFormat}">
                                                        <TextBlock Text="UTC формат"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type vm:DecTimeFormat}">
                                                        <TextBlock Text="Десятичный"/>
                                                    </DataTemplate>
                                                </ComboBox.Resources>
                                            </ComboBox>
                                        </Grid>

                                        <ContentPresenter Content="{Binding Path=CurrentFormat, Mode=OneWay}">
                                            <ContentPresenter.Resources>
                                                <DataTemplate DataType="{x:Type vm:FromPlusTimeCurveFormat}">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Дата начала" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <tookit:DateTimePicker Value="{Binding Path=From, Mode=TwoWay}" Format="ShortDate" Grid.Column="1" Margin="0"/>
                                                        </Grid>

                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Пар-р начала" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=FromParameter, Mode=TwoWay}" ItemsSource="{Binding Path=Parameters, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>

                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Кривая времени" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>

                                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=TwoWay}" Content="Реверсивный порядок"/>
                                                    </StackPanel>
                                                </DataTemplate>

                                                <DataTemplate DataType="{x:Type vm:DateDotTimeFormat}">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Кривая времени" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>
                                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=TwoWay}" Content="Реверсивный порядок"/>
                                                    </StackPanel>
                                                </DataTemplate>

                                                <DataTemplate DataType="{x:Type vm:ReverseDateDotTimeFormat}">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Кривая времени" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>
                                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=TwoWay}" Content="Реверсивный порядок"/>
                                                    </StackPanel>
                                                </DataTemplate>

                                                <DataTemplate DataType="{x:Type vm:ReverseDateTimeDotMSFormat}">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Кривая времени" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>
                                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=TwoWay}" Content="Реверсивный порядок"/>
                                                    </StackPanel>
                                                </DataTemplate>

                                                <DataTemplate DataType="{x:Type vm:OleTimeFormat}">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Кривая времени" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>

                                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=TwoWay}" Content="Реверсивный порядок"/>
                                                    </StackPanel>
                                                </DataTemplate>

                                                <DataTemplate DataType="{x:Type vm:UtcTimeFormat}">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Кривая времени" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>

                                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=TwoWay}" Content="Реверсивный порядок"/>
                                                    </StackPanel>
                                                </DataTemplate>

                                                <DataTemplate DataType="{x:Type vm:DecTimeFormat}">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid Margin="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="titleGroup"/>
                                                                <ColumnDefinition Width="{StaticResource valueWidth}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Кривая времени" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
                                                            <ComboBox SelectedItem="{Binding Path=Curve, Mode=TwoWay}" ItemsSource="{Binding Path=Curves, Mode=OneTime}" Grid.Column="1" Margin="0">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Path=Mnemonics}"/>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </Grid>

                                                        <CheckBox Margin="2" IsChecked="{Binding Path=IsReversed, Mode=TwoWay}" Content="Реверсивный порядок"/>
                                                    </StackPanel>
                                                </DataTemplate>

                                            </ContentPresenter.Resources>
                                        </ContentPresenter>
                                    </StackPanel>
                                </DataTemplate>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </StackPanel>
                </DockPanel>
            </GroupBox>

            <GroupBox Header="Предпросмотр" Grid.Column="2" Grid.Row="0">
                <ContentPresenter Content="{Binding Path=CurrentMetric, Mode=OneWay}">
                    <ContentPresenter.Resources>
                        <DataTemplate DataType="{x:Type vm:Depth}">
                            <DataGrid ItemsSource="{Binding Path=Preview, Mode=OneWay}"
                                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserSortColumns="False" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Номер строки" Binding="{Binding Path=Index, Mode=OneTime}" Width="100*"/>
                                    <DataGridTextColumn Header="Значение" Binding="{Binding Path=Depth, Mode=OneTime, StringFormat={}{0:F3}}" Width="100*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:Time}">
                            <DataGrid ItemsSource="{Binding Path=Preview, Mode=OneWay}"
                                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserSortColumns="False" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Номер строки" Binding="{Binding Path=Index, Mode=OneTime}" Width="100*"/>
                                    <DataGridTextColumn Header="Значение" Binding="{Binding Path=TimeStamp, Mode=OneTime, StringFormat={}{0:dd.MM.yyyy HH:mm:ss.fff}}" Width="100*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DataTemplate>
                    </ContentPresenter.Resources>
                </ContentPresenter>

            </GroupBox>
        </Grid>
    </DockPanel>
</UserControl>
