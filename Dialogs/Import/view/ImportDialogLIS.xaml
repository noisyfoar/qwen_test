<Window x:Class="NPFGEO.ShellExtension.Formats.LIS.Dialogs.Import.View.ImportDialogLIS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:view="clr-namespace:NPFGEO.ShellExtension.Formats.LIS.Dialogs.Import.View"
        xmlns:vm="clr-namespace:NPFGEO.ShellExtension.Formats.LIS.Dialogs.Import.ViewModel"
        xmlns:npfCommands ="clr-namespace:NPFGEO.Controls;assembly=GeoControls"
        mc:Ignorable="d"
        WindowStyle="ToolWindow" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" WindowState="Normal"
        Title="Импорт файла" Height="450" Width="720">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:TabCurvesDialogLIS}">
            <view:TabCurvesLIS/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TabFormatDialogLIS}">
            <view:TabFormatLIS/>
        </DataTemplate>

        <Style TargetType="Run" x:Key="StageStyle">
            <Setter Property="Foreground" Value="LightGray"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="LightGray"/>
                    <Setter Property="TextDecorations" Value="None"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static npfCommands:NPFGEOCommands.Apply}" CanExecute="Apply_CanExecute" Executed="Apply_Executed"/>
        <CommandBinding Command="{x:Static npfCommands:NPFGEOCommands.Cancel}" CanExecute="Cancel_CanExecute" Executed="Cancel_Executed"/>
    </Window.CommandBindings>


    <DockPanel>

        <UniformGrid DockPanel.Dock="Bottom" HorizontalAlignment="Right" Columns="4">
            <UniformGrid.Resources>
                <Style TargetType="Button">
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Padding" Value="14, 2, 14, 2"/>
                </Style>
            </UniformGrid.Resources>
            <Button Content="Отмена" Command="{x:Static npfCommands:NPFGEOCommands.Cancel}"/>
            <Button Content="&lt; Назад" Command="{Binding Path=PreviousCommand}"/>
            <Button Content="Далее &gt;" Command="{Binding Path=NextCommand}"/>
            <Button Content="Готово" Command="{x:Static npfCommands:NPFGEOCommands.Apply}"/>
        </UniformGrid>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10, 2, 10, 2">
            <TextBlock FontSize="14" >
                <Run Text="Выбор кривых" IsEnabled="{Binding Path=IsTabCurves, Mode=OneWay}" Style="{StaticResource StageStyle}"/>
                <Run Text="&gt;" Foreground="LightGray"/>
                <Run Text="Выбор форматирования" IsEnabled="{Binding Path=IsTabFormat, Mode=OneWay}" Style="{StaticResource StageStyle}"/>
            </TextBlock>
        </StackPanel>



        <ContentPresenter Content="{Binding Path=CurrentStage, Mode=OneWay}"/>
    </DockPanel>
</Window>
